	lc	r1,2
	ceq	r0,r1
	brt	_format_output_line_use_desc1
_format_output_line_return:
	RET1
_format_output_line_use_desc0:
	la	r0,_output_desc0_len
	la	r1,_selected_output_len_ptr
	sw	r0,0(r1)
	la	r1,_output_desc0_kind
