_format_output_line:
	FRAME1
	la	r1,_output_line_ready
	la	r0,0
	sw	r0,0(r1)
	la	r1,_active_output_len
	sw	r0,0(r1)
	la	r1,_selected_output_len_ptr
	sw	r0,0(r1)
	la	r1,_output_table_count
	lw	r0,0(r1)
	ceq	r0,z
	brt	_format_output_line_return
