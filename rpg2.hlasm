; rpg2.hlasm -- RPG-II Processor rewrite skeleton
; Current safe HLASM subset only:
; - plain assembly passthrough
; - no-argument macros
; - conditional assembly
; - no blank lines (current hlasm line reader treats a blank line as EOF)
;
; Current executable behavior intentionally stays at the deck-reader slice:
; read 80-byte records from a memory-backed deck descriptor,
; print the first 10 bytes of each record to UART, then halt.
;
; Future growth should fill in the parser/runtime placeholders in this file
; instead of returning to a monolithic hand-written .s layout.
SET SPIKE,1
; --- Configuration ---
; Test deck is loaded at 0x090000 by build.sh.
; UART data register at 0xFF0100 = -65280 signed.
; UART status register at 0xFF0101 = -65279 signed.
; Deck descriptor layout (12 bytes):
;   +0 base, +3 record length, +6 record count, +9 current index
; --- Structural macros ---
MACRO MAINPRO
 push fp
 mov fp,sp
MEND
MACRO MAINRET
 mov sp,fp
 pop fp
MEND
MACRO FRAME1
 push fp
 push r1
 mov fp,sp
MEND
MACRO RET1
 mov sp,fp
 pop r1
 pop fp
 jmp (r1)
MEND
MACRO FRAME21
 push fp
 push r2
 push r1
 mov fp,sp
MEND
MACRO RET21
 mov sp,fp
 pop r1
 pop r2
 pop fp
 jmp (r1)
MEND
; --- Descriptor helpers ---
; These remain no-argument until parameter substitution is reliable upstream.
MACRO DBASE0
 lw r0,0(r2)
MEND
MACRO DLEN2
 lw r2,3(r2)
MEND
MACRO DCOUNT1
 lw r1,6(r2)
MEND
MACRO DINDEX0
 lw r0,9(r2)
MEND
MACRO SP10
 .byte 32,32,32,32,32,32,32,32,32,32
MEND
MACRO SP8
 .byte 32,32,32,32,32,32,32,32
MEND
MACRO SP4
 .byte 32,32,32,32
MEND
; --- Rewrite-stage marker ---
IFDEF SPIKE
 nop
ENDIFASM
; --- Boot / top-level cycle ---
_main:
	MAINPRO
	la	r2,-65280
	la	r0,_rpg_cycle
	jal	r1,(r0)
	MAINRET
_halt:
	bra	_halt
; --- Runtime skeleton entry points ---
; These keep the high-level RPG-II shape visible even while the executable
; subset is still only the deck-reader demo.
_rpg_cycle:
	FRAME1
	la	r0,_rpg_cycle_startup
	jal	r1,(r0)
	ceq	r0,z
	brt	_rpg_cycle_total_phase
_rpg_cycle_detail_loop:
	la	r0,_rpg_cycle_detail
	jal	r1,(r0)
	ceq	r0,z
	brt	_rpg_cycle_total_phase
	bra	_rpg_cycle_detail_loop
_rpg_cycle_total_phase:
	la	r0,_rpg_cycle_total
	jal	r1,(r0)
	RET1
_rpg_cycle_startup:
	FRAME1
	la	r0,_init_runtime
	jal	r1,(r0)
	la	r1,_source_parse_ok
	lw	r0,0(r1)
	ceq	r0,z
	brt	_rpg_cycle_startup_fail
	la	r1,_indicator_runtime_ok
	lw	r0,0(r1)
	ceq	r0,z
	brt	_rpg_cycle_startup_fail
	la	r0,1
	bra	_rpg_cycle_startup_done
_rpg_cycle_startup_fail:
	la	r0,0
_rpg_cycle_startup_done:
	RET1
_init_runtime:
	FRAME1
	la	r0,_init_source_parser
