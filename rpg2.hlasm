	ceq	r0,r1
	brf	_format_output_line_select_by_field
	la	r1,_calc_desc0_src_field
	lw	r0,0(r1)
	lc	r1,1
	ceq	r0,r1
	brt	_format_output_line_use_desc2
_format_output_line_select_by_field:
	la	r1,_calc_desc0_src_field
	lw	r0,0(r1)
