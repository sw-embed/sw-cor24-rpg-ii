_format_output_line_loop:
	ceq	r0,z
	brt	_format_output_line_copy_done
	push	r0
	lbu	r0,0(r2)
	sb	r0,0(r1)
	pop	r0
	add	r2,1
	add	r1,1
	add	r0,-1
	bra	_format_output_line_loop
_format_output_line_copy_done:
	la	r1,_output_line_ready
	la	r0,1
	sw	r0,0(r1)
_format_output_line_done:
