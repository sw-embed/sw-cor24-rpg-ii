_run_cspec_calc1_rev:
	la	r2,_calc_field0_buf
	la	r0,_calc_field_len
	lw	r0,0(r0)
	add	r2,r0
	add	r2,-1
	la	r1,_calc_scratch_buf
_run_cspec_calc1_rev_loop:
	ceq	r0,z
	brt	_run_cspec_calc1_rev_copyback_setup
	push	r0
	lbu	r0,0(r2)
	sb	r0,0(r1)
	pop	r0
	add	r2,-1
	add	r1,1
	add	r0,-1
	bra	_run_cspec_calc1_rev_loop
_run_cspec_calc1_rev_copyback_setup:
	la	r2,_calc_scratch_buf
	la	r1,_calc_field0_buf
	la	r0,_calc_field_len
	lw	r0,0(r0)
_run_cspec_calc1_rev_copyback_loop:
	ceq	r0,z
	brt	_run_cspec_calc1_done
	push	r0
	lbu	r0,0(r2)
	sb	r0,0(r1)
	pop	r0
	add	r2,1
	add	r1,1
	add	r0,-1
	bra	_run_cspec_calc1_rev_copyback_loop
_run_cspec_calc1_move_select0:
	la	r1,_detail_field_ready
