_format_output_line_use_desc2:
	la	r0,_output_desc2_len
	la	r1,_selected_output_len_ptr
	sw	r0,0(r1)
	la	r1,_output_desc2_kind
	la	r2,_output_desc2_gate
_format_output_line_check_kind:
	lw	r0,0(r1)
	lc	r1,68
	ceq	r0,r1
	brf	_format_output_line_return
	lw	r0,0(r2)
	ceq	r0,z
	brt	_format_output_line_check_calc_ready
	lc	r1,1
	ceq	r0,r1
	brt	_format_output_line_gate_on
	lc	r1,2
	ceq	r0,r1
	brt	_format_output_line_gate_off
