; --- Indicator table slice ---
_init_indicator_table:
	FRAME21
	la	r2,_indicator_table
	lc	r1,16
_ind_zero_loop:
	ceq	r1,z
	brt	_ind_zero_done
	la	r0,0
	sb	r0,0(r2)
	add	r2,1
	add	r1,-1
	bra	_ind_zero_loop
_ind_zero_done:
	RET21
_set_ind:
	FRAME21
	lw	r0,9(fp)
	la	r2,_indicator_table
	add	r2,r0
	la	r0,1
	sb	r0,0(r2)
	RET21
_clear_ind:
	FRAME21
	lw	r0,9(fp)
	la	r2,_indicator_table
	add	r2,r0
	la	r0,0
	sb	r0,0(r2)
	RET21
_test_ind:
	FRAME21
	lw	r0,9(fp)
	la	r2,_indicator_table
	add	r2,r0
	lbu	r0,0(r2)
	RET21
; --- Executable deck-reader subset ---
; _read_record: Read next record from deck.
; Arg (on stack): deck_desc pointer
; Returns: r0 = address of record in deck, or 0 on EOF
_read_record:
	FRAME21
	lw	r2,9(fp)
	DCOUNT1
	DINDEX0
	clu	r0,r1
	brf	_eof
	DBASE0
	lw	r1,9(r2)
	push	r2
	DLEN2
	mul	r1,r2
	add	r0,r1
	pop	r2
	lw	r1,9(r2)
	add	r1,1
	sw	r1,9(r2)
	bra	_ret
_eof:
	la	r0,0
_ret:
	RET21
; _emit_output_line: Print active_output_len bytes from address to UART.
; Arg (on stack): pointer to bytes
_emit_output_line:
	FRAME21
	lw	r2,9(fp)
	la	r0,_active_output_len
	lw	r1,0(r0)
_emit_output_line_next_byte:
	ceq	r1,z
	brt	_emit_output_line_done
	lbu	r0,0(r2)
	push	r2
	push	r1
	push	r0
	la	r0,_emit_char
	jal	r1,(r0)
	add	sp,3
	pop	r1
	pop	r2
	add	r2,1
	add	r1,-1
	bra	_emit_output_line_next_byte
_emit_output_line_done:
	RET21
; _emit_crlf: Print CR+LF to UART.
_emit_crlf:
	FRAME1
	lc	r0,13
	push	r0
	la	r0,_emit_char
	jal	r1,(r0)
	add	sp,3
	lc	r0,10
	push	r0
	la	r0,_emit_char
	jal	r1,(r0)
	add	sp,3
	RET1
; _emit_char: Write one byte to UART (with TX busy-wait).
; Arg (on stack): byte value
_emit_char:
	FRAME1
	lw	r0,6(fp)
	la	r2,-65280
_poll:
	lb	r1,1(r2)
	cls	r1,z
	brt	_poll
	sb	r0,0(r2)
	RET1
